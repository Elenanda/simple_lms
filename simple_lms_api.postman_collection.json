{
  "info": {
    "name": "Simple LMS REST API",
    "description": "Koleksi lengkap untuk testing REST API Simple LMS dengan JWT Authentication dan Role-Based Access Control.\n\n## Cara Pakai:\n1. Jalankan **Register** untuk membuat akun\n2. Jalankan **Login** → salin `access_token` dari response\n3. Set variable `access_token` di environment, atau paste manual di endpoint yang membutuhkan auth\n4. Gunakan endpoint sesuai role (student/instructor/admin)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.0.0"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000",
      "type": "string"
    },
    {
      "key": "access_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "refresh_token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register - Student",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"student_andi\",\n  \"email\": \"andi@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"student\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Status 201', () => pm.response.to.have.status(201));"]
              }
            }
          ]
        },
        {
          "name": "Register - Instructor",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"instructor_budi\",\n  \"email\": \"budi@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"instructor\"\n}"
            }
          }
        },
        {
          "name": "Register - Admin",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin_super\",\n  \"email\": \"admin@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"admin\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"student_andi\",\n  \"password\": \"password123\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('access_token', json.access_token);",
                  "pm.collectionVariables.set('refresh_token', json.refresh_token);",
                  "console.log('Token saved:', json.access_token.substring(0, 20) + '...');"
                ]
              }
            }
          ]
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/auth/refresh",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('access_token', json.access_token);"
                ]
              }
            }
          ]
        },
        {
          "name": "Get My Profile (GET /me)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/api/auth/me"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has username', () => pm.expect(pm.response.json()).to.have.property('username'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Update Profile (PUT /me)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": "{{base_url}}/api/auth/me",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"first_name\": \"Andi\",\n  \"last_name\": \"Mahasiswa\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Courses (Public)",
      "item": [
        {
          "name": "List All Courses",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/courses?page=1&page_size=10",
              "host": ["{{base_url}}"],
              "path": ["api", "courses"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "page_size", "value": "10" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has pagination', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('total');",
                  "  pm.expect(json).to.have.property('results');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "List Courses with Search",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/courses?search=python&page=1&page_size=5",
              "host": ["{{base_url}}"],
              "path": ["api", "courses"],
              "query": [
                { "key": "search", "value": "python" },
                { "key": "page", "value": "1" },
                { "key": "page_size", "value": "5" }
              ]
            }
          }
        },
        {
          "name": "Get Course Detail",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/courses/1"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 or 404', () => {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 404]);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Courses (Instructor - Protected)",
      "item": [
        {
          "name": "Create Course [Login as Instructor first]",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": "{{base_url}}/api/courses",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Belajar Django Ninja dari Nol\",\n  \"description\": \"Kursus lengkap membangun REST API dengan Django Ninja, JWT Auth, dan RBAC.\",\n  \"category_id\": null\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "if(pm.response.code === 201) {",
                  "  pm.collectionVariables.set('course_id', pm.response.json().id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Update Course (PATCH)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": "{{base_url}}/api/courses/{{course_id}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Django Ninja REST API - Updated\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Courses (Admin - Protected)",
      "item": [
        {
          "name": "Delete Course [Login as Admin first]",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/api/courses/{{course_id}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 (deleted) or 403 (wrong role)', () => {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 403]);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Enrollments (Student - Protected)",
      "item": [
        {
          "name": "Enroll to Course [Login as Student]",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": "{{base_url}}/api/enrollments",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"course_id\": 1\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201 or 400 (already enrolled)', () => {",
                  "  pm.expect(pm.response.code).to.be.oneOf([201, 400]);",
                  "});",
                  "if(pm.response.code === 201) {",
                  "  pm.collectionVariables.set('enrollment_id', pm.response.json().id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Get My Courses",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/api/enrollments/my-courses"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"]
              }
            }
          ]
        },
        {
          "name": "Mark Lesson Complete",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": "{{base_url}}/api/enrollments/{{enrollment_id}}/progress",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"lesson_id\": 1,\n  \"is_completed\": true\n}"
            }
          }
        }
      ]
    },
    {
      "name": "RBAC Tests",
      "item": [
        {
          "name": "403 - Student tries to create course",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": "{{base_url}}/api/courses",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Test\",\n  \"description\": \"Should fail if logged in as student\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('403 if student', () => pm.response.to.have.status(403));"]
              }
            }
          ]
        },
        {
          "name": "401 - Unauthenticated access",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/auth/me"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('401 Unauthorized', () => pm.response.to.have.status(401));"]
              }
            }
          ]
        }
      ]
    }
  ]
}
